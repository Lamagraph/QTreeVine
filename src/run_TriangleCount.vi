use #lib::{Matrix,TriangleCount,Utils}

const matrix_file:String = "data/494_bus.mtx";

fn tc(&io: &IO, graph: Matrix::SparseMatrix[N64]) {
  let tc = TriangleCount::triangle_count(graph);
  match tc {
    (Result::Ok(tc)) {
      io.println("TC result: {tc.show()}");
    }
    (Result::Err(e)) {
      io.println("TC failed: {e.show()}");
    }
  }
}

pub fn main(&io: &IO) {
  let graph = Utils::read_mtx(&io, matrix_file, false);
  match graph {
    (Result::Ok(g)) { tc(&io, g) }
    (Result::Err(e)) {
      io.println("Data loading failed: {e}");
    }
  }
}
