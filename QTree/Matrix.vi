fn test_2x3_transposition(&io: &IO) {
  let tree = QTree::Node(
    QTree::Node(leaf_v(2[N64]), leaf_n(), leaf_n(), leaf_v(2[N64])),
    QTree::Node(leaf_v(2[N64]), leaf_d(), leaf_n(), leaf_d()),
    leaf_d(),
    leaf_d(),
  );

  let tree_expected = QTree::Node(
    QTree::Node(leaf_v(2[N64]), leaf_n(), leaf_n(), leaf_v(2[N64])),
    leaf_d(),
    QTree::Node(leaf_v(2[N64]), leaf_n(), leaf_d(), leaf_d()),
    leaf_d(),
  );

  let m1 = SparseMatrix(2[N64], 3[N64], 3[N64], Storage(4[N64], tree));

  let expected = SparseMatrix(3[N64], 2[N64], 3[N64], Storage(4[N64], tree_expected));

  let actual = transpose(m1);

  if actual == expected {
    io.println("PASS");
  } else {
    io.println("FAIL: 2x3 transposition");
  }
}

